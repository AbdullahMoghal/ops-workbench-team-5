# =============================================================================
# Warehouse Ops Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env to source control.
# =============================================================================

# Supabase Postgres connection string
# Found in: Supabase Dashboard > Project Settings > Database > Connection string (URI)
SUPABASE_DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres

# Supabase DB credentials
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-database-password

# Supabase JWT Secret
# Found in: Supabase Dashboard > Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Server port (default 8080)
PORT=8080

# Allowed CORS origins (frontend URL)
CORS_ORIGINS=http://localhost:5173
